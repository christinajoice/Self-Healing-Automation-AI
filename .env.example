# -------------------------------------------------------
# Browser Settings
# -------------------------------------------------------

# LOCAL development: set to false to see the browser window
# CLOUD deployment:  must be true (no display on cloud servers)
BROWSER_HEADLESS=true

# -------------------------------------------------------
# AI Locator Suggester Configuration
# -------------------------------------------------------

# --- Option 1: Ollama (LOCAL only — free, no internet needed) ---
# Install: https://ollama.com
# Pull model: ollama pull llama3.2
# Start:   ollama serve
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=llama3.2
AI_API_KEY=ollama

# --- Option 2: Groq (CLOUD friendly — free tier, needs API key) ---
# Sign up free: https://console.groq.com
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.1-8b-instant
# AI_API_KEY=your_groq_api_key_here

# --- Option 3: LM Studio (LOCAL — free, GUI-based) ---
# AI_BASE_URL=http://localhost:1234/v1
# AI_MODEL=llama3.2
# AI_API_KEY=lm-studio
